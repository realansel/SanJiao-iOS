        }
      }
    },
    "CFBundleName" : {
      "comment" : "Bundle name",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "青羽记账"
          }
        }
      }
    },
    "NSFaceIDUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID is used to unlock Quillion and protect your bookkeeping privacy."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用 Face ID 解锁青羽记账，保护你的账单隐私"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用 Face ID 解鎖青羽記帳，保護你的帳單隱私"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Microphone access is used to capture your voice when recording an entry by speaking."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用于语音记账时采集你的说话声音"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用於語音記帳時擷取你的說話聲音"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speech recognition turns what you say into an entry. Supported devices transcribe on-device; older devices use Apple's speech service."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把你说的话转写成账目。支持的机型在设备端离线完成；较旧机型会经 Apple 语音服务处理"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把你說的話轉寫成帳目。支援的機型在裝置端離線完成；較舊機型會經 Apple 語音服務處理"
          }
        }
      }
    },
    "NSUserNotificationsUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminds you to log an entry each day to build a tracking habit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天提醒你记一笔，养成记账习惯"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天提醒你記一筆，養成記帳習慣"
          }
        }
      }
    }
  },
  "version" : "1.0"
}